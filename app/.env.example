# Public Supabase project configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
NEXT_PUBLIC_APP_URL=https://emails.example.com

# Operational only: load for migration/seed commands, never in the web deployment runtime.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Server-only deployment secrets
GEMINI_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=

# Secure iframe access for GHL. Generate at least 32 random bytes and keep it server-only.
EMAILBUILDER_EMBED_TOKEN=
EMAILBUILDER_FRAME_ANCESTORS="'self' https://*.gohighlevel.com https://*.leadconnectorhq.com"

# Legacy emergency mode. Prefer EMAILBUILDER_EMBED_TOKEN; never expose this publicly.
EMAILBUILDER_OPEN_ACCESS=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=AD Media Solution
SMTP_FROM_EMAIL=

# Development only. Never enable in production.
EMAILBUILDER_AUTH_BYPASS=false
EMAILBUILDER_ENABLE_ETHEREAL=false
DEBUG_PROMPTS=false
